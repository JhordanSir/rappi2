# =============================================================================
#  Rappi2 — plantilla del .env ÚNICO (raíz). Copia a `.env` y rellena los valores.
#  Compose lee el .env de la raíz para resolver los ${...} de docker-compose.yml.
#  En Dokploy: pega el contenido de tu `.env` en la sección "Environment".
#
#   - VITE_*             → build-arg del frontend (se hornean en el bundle).
#   - resto              → environment del contenedor `api` (backend FastAPI).
#   - POSTGRES_*/MONGO_*  → inicializan las BD y arman DATABASE_URL / MONGO_URL.
# =============================================================================

# --- PostgreSQL (usa credenciales FUERTES en producción) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rappi2

# --- MongoDB ---
MONGO_USER=admin
MONGO_PASSWORD=admin
MONGO_DB=rappi2_mongo

# --- Autenticación: Keycloak (OIDC) ---
# La autenticación la provee Keycloak; el backend solo valida los tokens (no emite JWT).
# PUBLIC_URL = la que ve el navegador (issuer del token). INTERNAL_URL = cómo alcanza el
# backend a Keycloak dentro de la red (en docker-compose, http://keycloak:8080).
# EN PRODUCCIÓN: PUBLIC_URL debe ser el dominio HTTPS público de Keycloak (NO localhost),
# p. ej. https://auth.wayrasimi.tech — debe coincidir con VITE_KEYCLOAK_URL de abajo.
KEYCLOAK_PUBLIC_URL=http://localhost:8080
KEYCLOAK_INTERNAL_URL=http://keycloak:8080
KEYCLOAK_REALM=rappi2
KEYCLOAK_CLIENT_ID=rappi2-frontend
KEYCLOAK_AUDIENCE=rappi2-backend
# Admin de la consola de Keycloak (http://localhost:8080). Cámbialo en producción.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# --- SMTP (correos de recuperación de contraseña de Keycloak) ---
# El realm ya tiene el enlace "¿Olvidaste tu contraseña?" habilitado; para que el correo
# llegue de verdad, Keycloak necesita un servidor SMTP. Sin SMTP_HOST se importa sin SMTP
# (el enlace aparece pero no se envía nada). Sirve cualquier proveedor: Gmail, SendGrid,
# Mailgun, Amazon SES, Brevo, etc.
#   Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_STARTTLS=true,
#          SMTP_USER=tu@gmail.com, SMTP_PASSWORD=<contraseña de aplicación de 16 chars>
#          (una "App Password", NO tu contraseña normal; requiere verificación en 2 pasos).
# OJO: no uses comillas dobles (") ni barras invertidas (\) en SMTP_PASSWORD.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Remitente de los correos. Si se deja vacío, se usa SMTP_USER.
SMTP_FROM=
SMTP_FROM_DISPLAY=Rappi2
# TLS: usa STARTTLS (puerto 587) O SSL directo (puerto 465), no ambos a la vez.
SMTP_STARTTLS=true
SMTP_SSL=false
# Autenticación SMTP (déjalo en true salvo relay interno sin credenciales).
SMTP_AUTH=true

AUDIT_ENABLED=true
# En producción recórtalo a tu dominio: https://app.midominio.com (coma-separado)
CORS_ORIGINS='["*"]'

# --- URLs públicas (ajusta a tus dominios) ---
# FRONTEND_BASE_URL también se inyecta en el realm de Keycloak (redirectUris / Valid
# redirect URIs del cliente) al arrancar. EN PRODUCCIÓN = el dominio público del frontend,
# p. ej. https://rappi2.wayrasimi.tech
PUBLIC_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173

# --- Geocoding / ruteo ---
ORS_API_KEY=your_openrouteservice_api_key_here
GEOCODING_ENABLED=true
RUTA_AUTOGENERAR=true
GPS_TRACKING_RETENCION_DIAS=30

# --- MercadoPago (vacío = modo simulado) ---
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
MONEDA=PEN

# --- Validación de RUC (SUNAT) ---
# Sin SUNAT_API_URL solo se valida formato + dígito verificador (sin consulta externa).
# Con proveedor (apis.net.pe, apisperu, etc.): admite placeholder {ruc} o se añade ?numero=.
SUNAT_ENABLED=true
SUNAT_API_URL=
SUNAT_API_TOKEN=
SUNAT_TIMEOUT=6
# true = no bloquear la factura si SUNAT no responde; false = rechazar (502).
SUNAT_FALLO_ABIERTO=true

# --- Frontend (build-args de Vite) ---
VITE_API_URL=/api
# URL pública de Keycloak (la usa el navegador para el login OIDC).
# OJO: se "hornea" en el bundle en tiempo de BUILD -> si la cambias hay que RECONSTRUIR
# la imagen del frontend (no basta con reiniciar). EN PRODUCCIÓN = el dominio público de
# Keycloak (mismo valor que KEYCLOAK_PUBLIC_URL), p. ej. https://auth.wayrasimi.tech
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=rappi2
VITE_KEYCLOAK_CLIENT_ID=rappi2-frontend

# --- Runtime / infraestructura ---
PORT=8000
API_WORKERS=2
OSRM_REGION_URL=https://download.geofabrik.de/south-america/peru-latest.osm.pbf
