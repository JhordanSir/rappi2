# Variables a nivel de Docker Compose (Compose lee este .env de la raíz para
# resolver los ${...} de docker-compose.yml).
#
# - VITE_GOOGLE_CLIENT_ID: se pasa como build-arg al frontend (Vite lo hornea en el
#   bundle). Mismo valor que GOOGLE_CLIENT_ID.
# - GOOGLE_CLIENT_ID / GOOGLE_ROLE_MAP: se inyectan al contenedor del backend (api).
#   GOOGLE_ROLE_MAP es la allowlist email->rol; formato "correo:Rol,correo:Rol".

VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_ROLE_MAP=
