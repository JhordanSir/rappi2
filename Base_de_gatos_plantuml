@startuml
' Ocultar el ícono de clase, hacerlo estilo base de datos
hide circle
skinparam linetype ortho
skinparam TableBackgroundColor #F9F9F9
skinparam TableBorderColor #AAAAAA

' Definición de Entidades

entity "roles" as roles {
  * id : Integer <<PK>>
  --
  nombre : String(50) [UNIQUE]
}

entity "permisos" as permisos {
  * id : Integer <<PK>>
  --
  rol_id : Integer <<FK>>
  recurso : String(50)
  accion : String(20)
}

entity "usuarios" as usuarios {
  * id : Integer <<PK>>
  --
  rol_id : Integer <<FK>>
  cliente_id : Integer <<FK>> [UNIQUE]
  username : String(50) [UNIQUE]
  email : String(150) [UNIQUE]
  password_hash : Text
  activo : Boolean
  fecha_registro : DateTime
}

entity "tokens" as tokens {
  * id : Integer <<PK>>
  --
  usuario_id : Integer <<FK>>
  token : Text [UNIQUE]
  fecha_expiracion : DateTime
  revocado : Boolean
}

entity "clientes" as clientes {
  * id : Integer <<PK>>
  --
  nombre : String(100)
  email : String(150) [UNIQUE]
  telefono : String(20)
  cc_id : String(30)
  activo : Boolean
  fecha_registro : DateTime
}

entity "clientes_direcciones" as clientes_direcciones {
  * id : Integer <<PK>>
  --
  cliente_id : Integer <<FK>>
  direccion : String(200)
  distrito : String(80)
  ciudad : String(80)
  estado : String(80)
  pais : String(80)
  es_principal : Boolean
}

entity "vehiculos" as vehiculos {
  * placa : String(15) <<PK>>
  --
  tipo : String(40)
  capacidad_kg : Numeric(8, 2)
  estado : String(20)
  fecha_mantenimiento : DateTime
  activo : Boolean
}

entity "conductores" as conductores {
  * id : Integer <<PK>>
  --
  usuario_id : Integer <<FK>> [UNIQUE]
  vehiculo_placa : String(15) <<FK>>
  nombre : String(100)
  licencia : String(30) [UNIQUE]
  disponibilidad : String(20)
  activo : Boolean
}

entity "ordenes" as ordenes {
  * id : Integer <<PK>>
  --
  cliente_id : Integer <<FK>>
  estado : String(20)
  direccion_origen : String(200)
  distrito_origen : String(80)
  direccion_destino : String(200)
  distrito_destino : String(80)
  fecha_creacion : DateTime
  total : Numeric(10, 2)
}

entity "pagos" as pagos {
  * id : Integer <<PK>>
  --
  orden_id : Integer <<FK>>
  fecha_pago : DateTime
  monto : Numeric(10, 2)
  estado : String(20)
  referencia_banco : String(80)
}

entity "facturas" as facturas {
  * id : Integer <<PK>>
  --
  orden_id : Integer <<FK>>
  fecha : DateTime
  ruc : String(20)
  monto : Numeric(10, 2)
  url : Text
}

entity "asignaciones" as asignaciones {
  * id : Integer <<PK>>
  --
  orden_id : Integer <<FK>>
  conductor_id : Integer <<FK>>
  vehiculo_placa : String(15) <<FK>>
  estado : String(20)
  fecha_inicio : DateTime
  fecha_fin : DateTime
}

entity "rutas_planificadas" as rutas_planificadas {
  * id : Integer <<PK>>
  --
  orden_id : Integer <<FK>>
  distancia_km : Numeric(8, 2)
  tiempo_estimado : INTERVAL
}

entity "paradas" as paradas {
  * id : Integer <<PK>>
  --
  ruta_id : Integer <<FK>>
  orden_id : Integer <<FK>> (Opcional)
  direccion : String(200)
  distrito : String(80)
  secuencia : Integer
  fecha_paso : DateTime
  estado : String(20)
}

entity "incidencias" as incidencias {
  * id : Integer <<PK>>
  --
  asignacion_id : Integer <<FK>>
  tipo : String(50)
  fecha : DateTime
  severidad : Integer
  notas : Text
  evidencia_url : Text
}

' Relaciones (Cardinalidad basada en la definición técnica)

roles "1" -- "0..*" permisos : tiene
roles "1" -- "0..*" usuarios : asignado a

clientes "1" -- "0..1" usuarios : se loguea como
clientes "1" -- "0..*" clientes_direcciones : tiene
clientes "1" -- "0..*" ordenes : realiza

usuarios "1" -- "0..*" tokens : posee
usuarios "1" -- "0..1" conductores : asociado a

vehiculos "1" -- "0..*" conductores : utilizado por
vehiculos "1" -- "0..*" asignaciones : despachado en

conductores "1" -- "0..*" asignaciones : recibe

ordenes "1" -- "0..*" pagos : registra
ordenes "1" -- "0..*" facturas : emite
ordenes "1" -- "0..*" asignaciones : consta de
ordenes "1" -- "0..*" rutas_planificadas : tiene

rutas_planificadas "1" -- "0..*" paradas : contiene
ordenes "1" -- "0..*" paradas : puede asociar

asignaciones "1" -- "0..*" incidencias : genera
@enduml