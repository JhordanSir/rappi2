# URL base del API. En dev se usa el proxy de Vite (/api -> :8000), deja vacio o /api.
# En produccion apunta al backend, ej: https://api.midominio.com/api
VITE_API_URL=/api

# Google OAuth (Sign in with Google). Client ID de tipo "Web application" de Google
# Cloud Console; el mismo valor va en el backend (GOOGLE_CLIENT_ID). Vacio = el boton
# de Google no se muestra.
VITE_GOOGLE_CLIENT_ID=
