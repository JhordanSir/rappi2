POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rappi2

MONGO_USER=admin
MONGO_PASSWORD=admin
MONGO_DB=rappi2_mongo

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/rappi2
MONGO_URL=mongodb://admin:admin@mongodb:27017/

SECRET_KEY=change_me_to_a_random_64_char_string_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
AUDIT_ENABLED=true

# ORS solo se usa para geocodificar direcciones (texto -> lat/lon). Opcional.
ORS_API_KEY=your_openrouteservice_api_key_here

# Ruteo por calles (OSRM, sin API key). Por defecto el servidor público;
# para autónomo usa el override docker-compose.osrm.yml -> http://osrm:5000
OSRM_URL=https://router.project-osrm.org
RUTA_AUTOGENERAR=true
